{
  "name": "cordova-plugin-boogie-devicelink",
  "version": "0.1.0",
  "description": "Stateful BLE device runtime for Cordova apps (Android, iOS): device profiles, connection state machine, per-device operation queue, reconnect policies — built on a maintained fork of cordova-plugin-bluetoothle. JS global: DeviceLink (the raw BLE API stays available as bluetoothle).",
  "types": "./types/index.d.ts",
  "cordova": {
    "id": "cordova-plugin-boogie-devicelink",
    "platforms": [
      "android",
      "ios"
    ]
  },
  "scripts": {
    "test": "node --test tests/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boogie/cordova-plugin-boogie-devicelink.git"
  },
  "keywords": [
    "bluetooth",
    "bluetoothle",
    "ble",
    "devicelink",
    "device manager",
    "cordova",
    "ecosystem:cordova",
    "cordova-android",
    "cordova-ios"
  ],
  "engines": {
    "cordovaDependencies": {
      "4.3.0": {
        "cordova": ">=5.0.0",
        "cordova-android": ">=5.0.0"
      },
      "7.0.0": {
        "cordova": ">=100"
      }
    }
  },
  "author": "András Bártházi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/boogie/cordova-plugin-boogie-devicelink/issues"
  },
  "homepage": "https://github.com/boogie/cordova-plugin-boogie-devicelink#readme"
}
